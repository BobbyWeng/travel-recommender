# Travel Recommender - 环境变量配置
# 复制此文件为 .env 并填入真实值

# 数据库
DATABASE_URL=sqlite:///data/travel.db

# Amadeus API
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_ENV=sandbox

# Open-Meteo（无需 API Key）
OPEN_METEO_BASE_URL=https://archive-api.open-meteo.com

# OpenWeatherMap（可选补充）
OWM_API_KEY=

# GeoNames（可选）
GEONAMES_USERNAME=

# 应用配置
APP_ENV=development
CACHE_TTL_FLIGHT_HOURS=4
CACHE_TTL_HOTEL_HOURS=4
CACHE_TTL_WEATHER_HOURS=6
MOCK_SEED=42
ALLOW_MOCK_FALLBACK=true

# CORS（逗号分隔域名）
CORS_ORIGINS=http://localhost:3000

# Duffel Flight API（可选）
DUFFEL_ACCESS_TOKEN=
DUFFEL_BASE_URL=https://api.duffel.com
DUFFEL_TIMEOUT_SECONDS=30
DUFFEL_MAX_RETRIES=3
DUFFEL_ENABLED=false

# Flight provider selection: auto, amadeus, duffel, mock
FLIGHT_PROVIDER=auto

# LLM 配置（可选）
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gemini-flash-latest
LLM_API_TYPE=gemini
