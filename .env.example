# ============================
# Travel Recommender 后端环境变量
# ============================
# 复制本文件为 .env 后填入真实值
# 本文件可安全提交到 Git（不含真实密钥）

# ---------- 应用环境 ----------
# development | production | demo
APP_ENV=development

# ---------- 数据库 ----------
# 留空则使用默认 SQLite（data/travel.db）
# Render PostgreSQL 示例: postgresql://user:pass@host:5432/dbname
DATABASE_URL=

# ---------- CORS ----------
# 逗号分隔的前端域名
# 本地开发:
CORS_ORIGINS=http://localhost:3000
# 生产部署示例（替换为实际域名）:
# CORS_ORIGINS=http://localhost:3000,https://travel-recommender.vercel.app,https://your-app.vercel.app

# ---------- Mock / Demo 控制 ----------
# production 下必须为 false，禁止 Mock 伪装真实数据
# development/demo 下可为 true
ALLOW_MOCK_FALLBACK=true

# ---------- 缓存 TTL（小时） ----------
CACHE_TTL_FLIGHT_HOURS=4
CACHE_TTL_HOTEL_HOURS=4
CACHE_TTL_WEATHER_HOURS=6
MOCK_SEED=42

# ---------- Open-Meteo 天气（免费，无需 Key） ----------
OPEN_METEO_BASE_URL=https://archive-api.open-meteo.com

# ---------- LLM（AI 对话搜索 / 解释 / 建议） ----------
# 支持 Gemini 或 OpenAI 兼容 API
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gemini-flash-latest
LLM_API_TYPE=gemini

# ---------- Amadeus 航班 / 酒店（可选） ----------
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_ENV=sandbox

# ---------- Duffel 航班（可选） ----------
DUFFEL_ACCESS_TOKEN=
DUFFEL_BASE_URL=https://api.duffel.com
DUFFEL_TIMEOUT_SECONDS=30
DUFFEL_MAX_RETRIES=3
DUFFEL_ENABLED=false

# ---------- 航班 Provider 选择 ----------
# auto: 按优先级自动选择（Duffel > Amadeus > Mock）
# duffel: 仅使用 Duffel
# amadeus: 仅使用 Amadeus
# mock: 仅使用 Mock（production 下被禁止）
FLIGHT_PROVIDER=auto

# ---------- 其他可选 API ----------
OWM_API_KEY=
GEONAMES_USERNAME=
